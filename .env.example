# Anthropic API Configuration
# --------------------------
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-api-key-here

# Gmail IMAP Configuration
# --------------------------
# Your Gmail address
GMAIL_ADDRESS=your-email@gmail.com

# Gmail App Password (NOT your regular password)
# Generate one at: https://myaccount.google.com/apppasswords
# Requires 2-Factor Authentication to be enabled
GMAIL_APP_PASSWORD=your-app-password-here

# IMAP Server Settings (default for Gmail)
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993

# Polling Configuration
# --------------------------
# How often to check for new emails (in seconds)
POLL_INTERVAL_SECONDS=300

# Classification Configuration
# --------------------------
# Keywords that might indicate a support request (comma-separated)
SUPPORT_KEYWORDS=help,issue,problem,error,not working,broken,how do I,can't,unable,support,question

# Notion Configuration (optional - for searching help articles)
# --------------------------
# If you have a specific Notion database for help articles, add its ID here
# NOTION_HELP_DATABASE_ID=your-database-id

# Logging
# --------------------------
LOG_LEVEL=INFO
