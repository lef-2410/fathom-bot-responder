# Anthropic API
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key

# Fathom API
# Get your key from Fathom settings
FATHOM_API_KEY=your-fathom-api-key

# Notion API
# Create an integration at: https://www.notion.so/my-integrations
# Share your Call Tracker database with the integration
NOTION_API_KEY=your-notion-api-key
NOTION_DATABASE_ID=your-notion-database-id

# Gmail IMAP (app password, NOT your regular password)
# Generate at: https://myaccount.google.com/apppasswords
# Requires 2-Factor Authentication to be enabled
GMAIL_ADDRESS=your-email@example.com
GMAIL_APP_PASSWORD=your-app-password

# IMAP Server Settings (defaults work for Gmail)
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993

# User Identity (used in AI prompts and email drafting)
USER_NAME=Your Name
COMPANY_NAME=Your Company

# Polling interval in seconds (default: 900 = 15 minutes)
POLL_INTERVAL_SECONDS=900

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
